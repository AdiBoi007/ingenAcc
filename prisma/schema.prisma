// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id             String         @id @default(uuid())
  email          String         @unique
  password       String
  name           String?
  role           String         @default("STUDENT") // STUDENT, TUTOR, BOTH
  universityId   String?
  institution    Institution?   @relation(fields: [universityId], references: [id])
  panicModeActive Boolean       @default(false)
  createdAt      DateTime       @default(now())

  studentCourses StudentCourse[]
  studyBlocks    StudyBlock[]
  resourcesSold  Resource[]     @relation("Seller")
  batchClasses   BatchClass[]   @relation("Tutor")
}

model Institution {
  id        String   @id @default(uuid())
  name      String
  domain    String?
  users     User[]
  courses   Course[]
}

model Course {
  id             String         @id @default(uuid())
  institutionId  String
  code           String
  name           String
  description    String?

  institution    Institution     @relation(fields: [institutionId], references: [id])
  studentCourses StudentCourse[]
  assignments    Assignment[]
  resources      Resource[]
  batchClasses   BatchClass[]
}

model StudentCourse {
  id             String   @id @default(uuid())
  studentId      String
  courseId       String
  readinessScore Int?     @default(0) // 0-100
  status         String   @default("ACTIVE") // ACTIVE, COMPLETED

  user           User     @relation(fields: [studentId], references: [id])
  course         Course   @relation(fields: [courseId], references: [id])

  @@unique([studentId, courseId])
}

model Assignment {
  id          String    @id @default(uuid())
  courseId    String
  title       String
  type        String    // EXAM, ASSIGNMENT, QUIZ
  dueDate     DateTime?
  weighting   Float?    // Percentage of grade

  course      Course    @relation(fields: [courseId], references: [id])
}

model StudyBlock {
  id            String   @id @default(uuid())
  studentId     String
  title         String
  startTime     DateTime
  endTime       DateTime
  isAiGenerated Boolean  @default(false)
  status        String   @default("PENDING") // PENDING, IN_PROGRESS, COMPLETED

  user          User     @relation(fields: [studentId], references: [id])
}

model Resource {
  id          String   @id @default(uuid())
  sellerId    String
  courseId    String
  title       String
  description String?
  priceCents  Int      @default(0)
  fileUrl     String?
  format      String?  // PDF, Link, ZIP

  seller      User     @relation("Seller", fields: [sellerId], references: [id])
  course      Course   @relation(fields: [courseId], references: [id])
}

model BatchClass {
  id          String   @id @default(uuid())
  tutorId     String
  courseId    String
  title       String
  startTime   DateTime
  endTime     DateTime
  maxSeats    Int      @default(20)
  priceCents  Int      @default(0)

  tutor       User     @relation("Tutor", fields: [tutorId], references: [id])
  course      Course   @relation(fields: [courseId], references: [id])
}
